<IfModule mod_rewrite.c>
RewriteEngine On
Options -Indexes

# Custom 404 Error Page 
ErrorDocument 404 /404.php

# 0a. Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 0b. Forcer www (https://garageraymond.fr → https://www.garageraymond.fr)
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 1. Éviter d'avoir .php dans l'URL si tapé directement (Redirection SEO 301)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(.*)\.php$ $1 [R=301,L]

# 2. Gestion automatique des catégories existantes
RewriteRule ^(assurance|entretien|electrique|occasion|moto|permis)/?$ category.php?cat=$1 [L,QSA]

# 3. Redirection 301 permanente : /Blog/slug → /slug (supprime le préfixe Blog des URLs)
RewriteRule ^Blog/([a-z0-9\-]+)/?$ /$1 [R=301,L]

# 3bis. Images orphelines 404 → redirections vers équivalents existants
RewriteRule ^Image/record-kilometrage-pan-european-1300-([2-4])\.webp$ /Image/record-kilometrage-pan-european-1300$1.webp [R=301,L]
RewriteRule ^Image/comment-installer-un-kit-de-rabaissement-moto-4\.webp$ /Image/comment-installer-un-kit-de-rabaissement-moto3.webp [R=301,L]

# 3b. Annuaire des marques : /marques/ → marques.php (priorité sur le dossier physique)
RewriteRule ^marques/?$ marques.php [L]

# 3c. Index par lettre : /marques/a/ → marques/a.php (idem, dossier réel ignoré)
RewriteRule ^marques/([a-z])/?$ marques/$1.php [L]

# 3d. Pages marques individuelles : /marques/audi → marques/audi.php
RewriteRule ^marques/([a-z0-9\-]+)/?$ marques/$1.php [L,QSA]

# 4. Rediriger l'URL propre vers le fichier PHP s'il existe sur le serveur
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

</IfModule>

# 5. Forcer le self-canonical dans les Headers HTTP (SEO)
<IfModule mod_headers.c>
    # On stocke l'URI demandée dans l'environnement
    SetEnvIf Req