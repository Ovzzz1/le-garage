<IfModule mod_rewrite.c>
RewriteEngine On
Options -Indexes

# Custom 404 Error Page 
ErrorDocument 404 /404.php

# 0a. Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 0b. Forcer www (https://garageraymond.fr → https://www.garageraymond.fr)
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 1. Éviter d'avoir .php dans l'URL si tapé directement (Redirection SEO 301)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(.*)\\.php$ $1 [R=301,L]

# 2. Gestion automatique des catégories existantes
RewriteRule ^(assurance|entretien|electrique|occasion|moto|permis)/?$ category.php?cat=$1 [L,QSA]

# 3. Gestion des articles dans Blog/ (URLs propres)
RewriteRule ^Blog/([a-z0-9\-]+)/?$ Blog/$1.php [L,QSA]

# 3b. Annuaire des marques : /marques/ → marques.php (priorité sur le dossier physique)
RewriteRule ^marques/?$ marques.php [L]

# 3c. Index par lettre : /marques/a/ → marques/a.php (idem, dossier réel ignoré)
RewriteRule ^marques/([a-z])/?$ marques/$1.php [L]

# 3d. Pages marques individuelles : /marques/audi → marques/audi.php
RewriteRule ^marques/([a-z0-9\-]+)/?$ marques/$1.php [L,QSA]

# 4. Rediriger l'URL propre vers le fichier PHP s'il existe sur le serveur
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

</IfModule>

# 5. Forcer le self-canonical dans les Headers HTTP (SEO)
<IfModule mod_headers.c>
    # On stocke l'URI demandée dans l'environnement
    SetEnvIf Request_URI "^(.*)$" REQ_URI=$1
    # On évite d'ajouter le header sur les fichiers statiques pour économiser de la bande passante
    SetEnvIf Request_URI "\.(css|js|jpg|jpeg|png|gif|webp|svg|woff|woff2|ico|pdf|txt)$" IS_ASSET
    # On injecte le header "Link" avec l'attribut rel="canonical"
    Header set Link "<https://www.garageraymond.fr%{REQ_URI}e>; rel=\"canonical\"" env=!IS_ASSET
</IfModule>
